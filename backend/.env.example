SECRET_KEY=replace-with-a-long-random-string
DATABASE_URL=sqlite:///./usermanager.db
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-please
POLL_INTERVAL_SECONDS=30

# RADIUS server (auth+accounting for OpenVPN/L2TP on MikroTik)
RADIUS_ENABLED=true
RADIUS_BIND_HOST=0.0.0.0
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_HOSTS_REFRESH_SECONDS=60
# Public IP/host of this panel, as reachable from your router - used as the
# default value in the "push RADIUS config" button if you don't type one.
PANEL_PUBLIC_HOST=
